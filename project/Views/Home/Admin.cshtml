<div class="container section">
    <h3 style="color:var(--brand)"><i class="bi bi-shield-lock"></i> Company Official Dashboard</h3>
    <p class="text-muted">Manage and update records across the system.</p>

    <div class="row g-3 my-3">
        <div class="col-md-3"><div class="dashboard-card bg-grad-1"><h6>Total Users</h6><h2 id="s-users">0</h2></div></div>
        <div class="col-md-3"><div class="dashboard-card bg-grad-2"><h6>Total Policies</h6><h2 id="s-pol">0</h2></div></div>
        <div class="col-md-3"><div class="dashboard-card bg-grad-3"><h6>Revenue</h6><h2>$<span id="s-rev">0</span></h2></div></div>
        <div class="col-md-3"><div class="dashboard-card bg-grad-4"><h6>Loan Requests</h6><h2 id="s-loans">0</h2></div></div>
    </div>

    <ul class="nav nav-tabs mt-4" id="tab" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-pol">Policies</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-users">Users</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-loans">Loans</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-pay">Payments</button></li>
    </ul>
    <div class="tab-content border border-top-0 p-3 bg-white">
        <div class="tab-pane fade show active" id="tab-pol"><div class="table-responsive"><table class="table"><thead><tr><th>ID</th><th>User</th><th>Type</th><th>Sum</th><th>Term</th><th>Status</th><th>Action</th></tr></thead><tbody id="t-pol"></tbody></table></div></div>
        <div class="tab-pane fade" id="tab-users"><div class="table-responsive"><table class="table"><thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Role</th></tr></thead><tbody id="t-users"></tbody></table></div></div>
        <div class="tab-pane fade" id="tab-loans"><div class="table-responsive"><table class="table"><thead><tr><th>ID</th><th>User</th><th>Amount</th><th>Purpose</th><th>Tenure</th><th>Status</th><th>Action</th></tr></thead><tbody id="t-loans"></tbody></table></div></div>
        <div class="tab-pane fade" id="tab-pay"><div class="table-responsive"><table class="table"><thead><tr><th>Txn</th><th>Policy</th><th>User</th><th>Amount</th><th>Date</th></tr></thead><tbody id="t-pay"></tbody></table></div></div>
    </div>
</div>