<div class="container">
    <div class="form-box">
        <h3 class="text-center mb-4" style="color:var(--brand)"><i class="bi bi-box-arrow-in-right"></i> Login</h3>
        <form onsubmit="loginUser(event)">
            <div class="mb-3"><label class="form-label">Email</label><input name="email" type="email" required class="form-control"></div>
            <div class="mb-3"><label class="form-label">Password</label><input name="password" type="password" required class="form-control"></div>
            <button class="btn btn-accent w-100">Login</button>
            <p class="text-center mt-3 small">New user? <a href="register.html">Register here</a></p>
            <div class="alert alert-info small mt-3 mb-0">
                <b>Admin demo:</b> admin@ims.com / admin123
            </div>
        </form>
    </div>
</div>