<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - project</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/project.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-brand navbar-dark sticky-top shadow-sm">
            <div class="container">

                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shield-check me-2"></i>
                    SecureLife IMS
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#nav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="nav">

                    <!-- Left side links -->
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Services">
                                Services
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Schemes">
                                Schemes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Calculator">
                                Premium Calc
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Loan">
                                Apply Loan
                            </a>
                        </li>
                    </ul>

                    <!-- Right side links (Login / Register) -->
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Login">
                                Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-accent ms-2 px-3" asp-area="" asp-controller="Home" asp-action="Register">
                                Register
                            </a>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="">
        <main role="" class="">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-brand text-light pt-5 pb-3 mt-5">

        <div class="container">

            <div class="row gy-4">

                <!-- Company Info -->
                <div class="col-md-4">

                    <h4 class="fw-bold mb-3">
                        <i class="bi bi-shield-check me-2"></i>
                        SecureLife IMS
                    </h4>

                    <p class="small">
                        Trusted online insurance management system
                        protecting your future with secure and reliable services.
                    </p>

                    <!-- Social Icons -->
                    <div class="mt-3">

                        <a href="#" class="text-light me-3 fs-5">
                            <i class="bi bi-facebook"></i>
                        </a>

                        <a href="#" class="text-light me-3 fs-5">
                            <i class="bi bi-instagram"></i>
                        </a>

                        <a href="#" class="text-light me-3 fs-5">
                            <i class="bi bi-twitter-x"></i>
                        </a>

                        <a href="#" class="text-light fs-5">
                            <i class="bi bi-linkedin"></i>
                        </a>

                    </div>

                </div>

                <!-- Quick Links -->
                <div class="col-md-4">

                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-link-45deg me-2"></i>
                        Quick Links
                    </h5>

                    <a href="services.html"
                           class="d-block py-1 text-decoration-none text-light">
                        <i class="bi bi-check-circle me-2"></i>
                        Insurance Services
                    </a>

                    <a href="schemes.html"
                           class="d-block py-1 text-decoration-none text-light">
                        <i class="bi bi-check-circle me-2"></i>
                        Subsidiary Schemes
                    </a>

                    <a href="calculator.html"
                           class="d-block py-1 text-decoration-none text-light">
                        <i class="bi bi-check-circle me-2"></i>
                        Premium Calculator
                    </a>

                    <a href="loan.html"
                           class="d-block py-1 text-decoration-none text-light">
                        <i class="bi bi-check-circle me-2"></i>
                        Loan Application
                    </a>

                </div>

                <!-- Contact -->
                <div class="col-md-4">

                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-headset me-2"></i>
                        Contact Us
                    </h5>

                    <p>
                        <i class="bi bi-geo-alt-fill me-2"></i>
                        221B Business Avenue, NY
                    </p>

                    <p>
                        <i class="bi bi-telephone-fill me-2"></i>
                        +1 800 555 0199
                    </p>

                    <p>
                        <i class="bi bi-envelope-fill me-2"></i>
                        support@securelife.com
                    </p>

                </div>

            </div>

            <hr class="border-light opacity-25 mt-4">

            <p class="text-center mb-0 small">
                <i class="bi bi-c-circle me-1"></i>
                2026 SecureLife Insurance.
                All Rights Reserved.
            </p>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
